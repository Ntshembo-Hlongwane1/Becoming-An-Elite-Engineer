{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++ (Codeforces)",
            "type": "cppbuild",
            "command": "g++",
            "args": [
                "-g",
                "-std=c++17",
                "-O2",
                "-Wall",
                "-Wextra",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Compile the currently open .cpp file"
        }
    ]
}
